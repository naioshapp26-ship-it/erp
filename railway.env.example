# Railway ERP service variables (set in Railway Dashboard → ERP service → Variables)
# Use "Add Reference" and select your PostgreSQL service — do NOT type these manually.

DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_PUBLIC_URL=${{Postgres.DATABASE_PUBLIC_URL}}
DATABASE_SSL=true
NODE_ENV=production
BASE_DOMAIN=web-production-419e2.up.railway.app
TENANT_DB_ENCRYPTION_KEY=b3b7710a9b1be04eb02f35f1a2d53bfb7c80173a0b289c4f029e34364cc26535

