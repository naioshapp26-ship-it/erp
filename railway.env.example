# Railway ERP service variables (Railway Dashboard → ERP service → Variables)
# IMPORTANT: use "Add Reference" — never paste an old DATABASE_URL manually.

DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_PUBLIC_URL=${{Postgres.DATABASE_PUBLIC_URL}}
DATABASE_SSL=false
NODE_ENV=production
BASE_DOMAIN=vendoworld.com
TENANT_SUBDOMAIN_URLS=true

# Subdomain DNS (required for tenant login links like https://moka.vendoworld.com):
# 1) Domain DNS: add wildcard CNAME  *.vendoworld.com  ->  <your-railway-service>.up.railway.app
# 2) Railway: ERP service -> Settings -> Networking -> Custom Domain -> add *.vendoworld.com
# 3) Optional apex: vendoworld.com can stay on another host; tenant subdomains must point to Railway.

# Remove from ERP if present (stale credentials break login):
# PROVISION_DB_URL, PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE

# Verify after deploy:
# GET /api/db-connect-test  → connected: true
# GET /api/auth/ping        → database: "connected"
