# Railway ERP service variables (Railway Dashboard → ERP service → Variables)
# IMPORTANT: use "Add Reference" — never paste an old DATABASE_URL manually.

DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_SSL=false
NODE_ENV=production
BASE_DOMAIN=vendoworld.com

# Remove from ERP if present (stale credentials break login):
# PROVISION_DB_URL, PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE

# Verify after deploy:
# GET /api/db-connect-test  → connected: true
# GET /api/auth/ping        → database: "connected"
