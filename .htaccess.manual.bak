# NAIOSH ERP — ضع هذا الملف في Application Root
# IMPORTANT: اترك كتلة Passenger التي يولّدها cPanel في الأعلى كما هي.

<IfModule mod_rewrite.c>
RewriteEngine On

# /api/* → Node (Passenger) — لا تُعاد كـ Betacademy SPA
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^ - [L]
</IfModule>

# إن وُجد index.html لـ SPA آخر (Betacademy) بقواعد Rewrite عامة،
# أضف بعد كتلة Passenger:
# RewriteCond %{REQUEST_URI} !^/api/
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteRule ^ index.html [L]
