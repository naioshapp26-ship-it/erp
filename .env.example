# ========================================
# NAYOSH ERP — Environment Variables
# Copy to .env and adjust values
# ========================================

# REQUIRED — PostgreSQL connection string
# Local example:
# DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE_NAME
#
# Railway example (ERP service → Variables):
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# DATABASE_PUBLIC_URL=${{Postgres.DATABASE_PUBLIC_URL}}
# DATABASE_SSL=true
#
# NEVER use placeholder hosts like "base", "db", or "localhost" in production.
#
# Obtain Railway DATABASE_URL from:
# Railway Dashboard → PostgreSQL service → Connect → Public Network → Connection URL
DATABASE_URL=

# false for local PostgreSQL | true for Railway/cloud PostgreSQL
# If omitted, SSL is auto-enabled for *.proxy.rlwy.net hosts
DATABASE_SSL=false

NODE_ENV=production

# Railway sets PORT automatically — do not hardcode in production
HOST=0.0.0.0

# Main domain for tenant subdomains (e.g. tenant.example.com)
BASE_DOMAIN=your-main-domain.com

TRUST_PROXY=1
UPLOADS_ROOT_DIR=uploads

# REQUIRED for multi-tenant DB encryption (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TENANT_DB_ENCRYPTION_KEY=

# Optional — tenant provisioning (only if using separate tenant databases)
# PROVISION_DB_URL=
# TENANT_DB_URL_TEMPLATE=postgresql://USER:PASSWORD@HOST:5432/{db}

# Optional diagnostics
DEBUG_AUTH=0
PG_POOL_MAX=4
TENANT_POOL_TTL_MS=1800000
