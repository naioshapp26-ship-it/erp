# ========================================
# NAYOSH ERP — قالب متغيرات البيئة
# انسخ إلى .env وعدّل القيم
# ========================================

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME

# false على cPanel مع PostgreSQL محلي | true لـ Railway/خدمات سحابية
DATABASE_SSL=false

NODE_ENV=production
# لا تضبط PORT على cPanel — يُعيَّن تلقائياً
HOST=0.0.0.0

# مثال: vendoworld.com إذا كان التطبيق على tenant.vendoworld.com
BASE_DOMAIN=your-main-domain.com

TRUST_PROXY=1
UPLOADS_ROOT_DIR=uploads

# 1 = إظهار stack trace في ردود /api/auth (للتشخيص فقط)
DEBUG_AUTH=0

# أنشئ مفتاحاً جديداً: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TENANT_DB_ENCRYPTION_KEY=
